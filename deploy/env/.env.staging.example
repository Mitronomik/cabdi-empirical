# Copy to deploy/.env before launching compose.
# Non-local posture is Postgres-only (PILOT_DB_URL is wired in compose).

POSTGRES_DB=cabdi_pilot
POSTGRES_USER=cabdi
POSTGRES_PASSWORD=replace-with-strong-postgres-password

# Participant-facing public origin(s), comma-separated.
PILOT_PARTICIPANT_CORS_ORIGINS=https://participant.example.org

# Researcher-facing private origin(s), comma-separated.
PILOT_RESEARCHER_CORS_ORIGINS=https://researcher.internal.example.org

# Required for researcher/admin auth bootstrap + cookie signing.
PILOT_RESEARCHER_PASSWORD=replace-with-strong-bootstrap-password
# Use 32+ chars high-entropy secret. Placeholder-like values are rejected in staging/prod.
PILOT_RESEARCHER_SESSION_SECRET=replace-with-long-random-secret-at-least-32-chars
