FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt && pip install --no-cache-dir uvicorn

COPY app ./app
COPY pilot ./pilot
COPY packages ./packages
COPY policies ./policies

EXPOSE 8000
